[sub_resource type="GDScript" id="GDScript_uddg2"]
script/source = "class_name Overlay
extends Control

@onready var overlay2: Control = %Overlay2

func _ready() -> void:
	Events.overlay_icon_clicked.connect(_on_overlay_icon_clicked)

func _on_overlay_icon_clicked(view_name: String) -> void:
	if view_name == \"pets\":
		overlay2.visible = true
"

